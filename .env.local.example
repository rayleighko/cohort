# =============================================================================
# Cohort — environment variables (.env.local.example)
# Copy to .env.local and fill. Never commit .env.local.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API (Aurora + Vesper personas + safety filter) ------------------
ANTHROPIC_API_KEY=

# --- Toss Payments (Korean, KRW V1) -----------------------------------------
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
TOSS_PAYMENTS_WEBHOOK_SECRET=

# --- 카카오 비즈메시지 (Tier 2+, W4 prerequisite) ---------------------------
KAKAO_BIZ_API_KEY=
KAKAO_BIZ_SENDER_KEY=

# --- Web Push (VAPID) -------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@cohort.co.kr

# --- Macro data sources -----------------------------------------------------
ECOS_API_KEY=                     # 한국은행 ECOS
FRED_API_KEY=                     # St. Louis Fed FRED
DART_API_KEY=                     # 금융감독원 DART

# --- Analytics + Monitoring -------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=

# --- App config -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://cohort.co.kr
NEXT_PUBLIC_APP_NAME=Cohort
