# =============================================================================
# Cohort — environment variables (.env.local.example)
# Copy to .env.local and fill. Never commit .env.local.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API (Aurora + Vesper personas + safety filter) ------------------
ANTHROPIC_API_KEY=

# Aurora chat model routing — vault 62 §2.1 (CEO confirm 2026-05-25).
# V1 default: 'false' (or unset) → always Sonnet.
# V1.5 enable: 'true' → shouldUseSonnet() heuristic active (Haiku/Sonnet
# per-turn routing). Toggle by updating the Vercel env var + Redeploy;
# no code change required.
AURORA_MODEL_ROUTING_ENABLED=false

# --- Polar (payment, MoR, USD billing) --------------------------------------
# Provider locked 2026-05-21: Polar primary, Lemon Squeezy fallback.
POLAR_ACCESS_TOKEN=                # sandbox.polar.sh → Settings (sandbox token)
POLAR_WEBHOOK_SECRET=              # Polar dashboard → Webhooks → endpoint secret
POLAR_ORGANIZATION_ID=             # Polar org id
POLAR_SERVER=sandbox               # 'sandbox' | 'production' (swap at W5 launch)
POLAR_PRODUCT_ID_PRO=              # Polar product id — Pro tier
POLAR_PRODUCT_ID_PREMIUM=          # Polar product id — Premium tier

# --- 카카오 비즈메시지 (Tier 2+, W4 prerequisite) ---------------------------
KAKAO_BIZ_API_KEY=
KAKAO_BIZ_SENDER_KEY=

# --- Web Push (VAPID) -------------------------------------------------------
# Generate keys: npx web-push generate-vapid-keys
# Public key is exposed twice: NEXT_PUBLIC_VAPID_PUBLIC_KEY (client SW subscribe)
# and VAPID_PUBLIC_KEY (server send via web-push). Same value, two names.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@cohort.co.kr

# --- Macro data sources -----------------------------------------------------
ECOS_API_KEY=                     # 한국은행 ECOS
FRED_API_KEY=                     # St. Louis Fed FRED
DART_API_KEY=                     # 금융감독원 DART

# --- Analytics + Monitoring -------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=

# --- App config -------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://cohort.co.kr
NEXT_PUBLIC_APP_NAME=Cohort

# --- Vercel Cron -----------------------------------------------------------
# Generate with: openssl rand -base64 32
# Add to .env.local AND Vercel dashboard (Production + Preview + Development)
# Then redeploy on Vercel for changes to take effect.
CRON_SECRET=
